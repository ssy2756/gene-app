# unpdf declares a peerOptional dependency on @napi-rs/canvas@^0.1.69, but
# this project uses @napi-rs/canvas@^1.0.2 (also required by pdfjs-dist).
# unpdf works fine against the 1.x API in practice (verified locally) —
# without this, `npm install` fails outright with ERESOLVE on Vercel's build.
legacy-peer-deps=true
